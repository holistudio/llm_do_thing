        <mxCell id="xELkamH10cSAUg8blqq6-35" value="word_sampling()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="1040" y="200" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-38" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;dashed=1;" parent="1" source="xELkamH10cSAUg8blqq6-37" target="xELkamH10cSAUg8blqq6-35" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-37" value="TARGET WORD&amp;nbsp;&lt;div&gt;LIST&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="1240" y="120" width="120" height="200" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-39" value="when people play this, they generally don&#39;t know the limited set of possible words that could be the target word.&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;buuut it could make training a lot easier if the LLM_guesser has a constrained output&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=6;spacingRight=6;fontColor=#D6B656;" parent="1" vertex="1">
          <mxGeometry x="1370" y="120" width="200" height="160" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-43" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="xELkamH10cSAUg8blqq6-41" target="xELkamH10cSAUg8blqq6-2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-63" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.25;entryDx=0;entryDy=0;" parent="1" source="xELkamH10cSAUg8blqq6-41" target="xELkamH10cSAUg8blqq6-5" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="260" y="240" />
              <mxPoint x="260" y="470" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-41" value="tokenizer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="280" y="220" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-47" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" parent="1" source="xELkamH10cSAUg8blqq6-44" target="xELkamH10cSAUg8blqq6-45" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-44" value="GUESS_WORD" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="1040" y="120" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="4vMMbXkcGmKN92a3yRBz-1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;exitX=0.25;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="xELkamH10cSAUg8blqq6-45" target="xELkamH10cSAUg8blqq6-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-45" value="reward_function()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="820" y="120" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-51" value="a reward function should provide some feedback signal based on whether the LLM_guesser guesses the original target word within a certain number of attempts by LLM_speaker&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;the big question is how can this reward function be used to fine-tune the LLM_speaker weights?&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=6;spacingRight=6;fontColor=#B85450;" parent="1" vertex="1">
          <mxGeometry x="610" y="-50" width="200" height="170" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-52" value="length of WORD_SEQUENCE is basically the number of attempts made by LLM_speaker&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;this can inform the reward function so that the LLM_speaker can learn the number of attempts&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=6;spacingRight=6;fontColor=#D6B656;" parent="1" vertex="1">
          <mxGeometry x="660" y="360" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-55" value="an embedding model can compute a continuous error/distance value (e.g. cosine similarity) between the TARGET and GUESS WORD to offer a more precise feedback score." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=6;spacingRight=6;fontColor=#D6B656;" parent="1" vertex="1">
          <mxGeometry x="950" y="-120" width="200" height="110" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-56" value="does the LLM_guesser also need to be trained or can its weights remain frozen?" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=6;spacingRight=6;fontColor=#D6B656;" parent="1" vertex="1">
          <mxGeometry x="1170" y="350" width="120" height="100" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-59" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" parent="1" source="xELkamH10cSAUg8blqq6-58" target="xELkamH10cSAUg8blqq6-32" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-64" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="xELkamH10cSAUg8blqq6-58" target="xELkamH10cSAUg8blqq6-35" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1020" y="500" />
              <mxPoint x="1020" y="220" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-58" value="tokenizer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="1040" y="480" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-60" value="&lt;i&gt;if training neural nets from scratch, choice of tokenizer could also have a major impact&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=6;spacingRight=6;fontColor=#D6B656;" parent="1" vertex="1">
          <mxGeometry x="460" y="170" width="120" height="90" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-61" value="does LLM_guesser have to be the same as LLM_speaker?" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=6;spacingRight=6;fontColor=#D6B656;" parent="1" vertex="1">
          <mxGeometry x="1170" y="480" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-62" value="how much of the pre-trained LLM should be fine-tuned? does it need extra layers?" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=6;spacingRight=6;fontColor=#B85450;" parent="1" vertex="1">
          <mxGeometry x="460" y="280" width="120" height="120" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-65" value="&lt;font color=&quot;#82b366&quot;&gt;for common token encodings like byte-wise pair encoding (BPE), careful consideration should be given to how the logits/tokens can be sampled to constrain the output to within a limited set of words&lt;/font&gt;&lt;div&gt;&lt;font color=&quot;#82b366&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#82b366&quot;&gt;on the other hand, additional network layers can be added to LLM_speaker to arrive at a set of logits, one for each in the Say-Thing Vocabulary.&lt;/font&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82B366;align=left;verticalAlign=top;spacingLeft=6;spacingRight=6;" parent="1" vertex="1">
          <mxGeometry x="-110" y="440" width="200" height="200" as="geometry" />
        </mxCell>
        <mxCell id="vskGLWChcw3Ok_nhiWOU-2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;dashed=1;" edge="1" parent="1" source="vskGLWChcw3Ok_nhiWOU-1" target="xELkamH10cSAUg8blqq6-45">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="vskGLWChcw3Ok_nhiWOU-1" value="LLM_embedding" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="820" y="-50" width="120" height="50" as="geometry" />
        </mxCell>
      </root>
