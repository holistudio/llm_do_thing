        <mxCell id="xELkamH10cSAUg8blqq6-62" value="how much of the pre-trained LLM should be fine-tuned? does it need extra layers?" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=6;spacingRight=6;fontColor=#B85450;" vertex="1" parent="1">
