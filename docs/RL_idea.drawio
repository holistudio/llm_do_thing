        <mxCell id="xELkamH10cSAUg8blqq6-45" value="reward_function()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="820" y="120" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-51" value="a reward function should provide some feedback signal based on whether the LLM_guesser guesses the original target word within a certain number of attempts by LLM_speaker&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;the big question is how can this reward function be used to fine-tune the LLM_speaker weights?&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=6;spacingRight=6;fontColor=#B85450;" vertex="1" parent="1">
          <mxGeometry x="610" y="-50" width="200" height="170" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-52" value="length of WORD_SEQUENCE is basically the number of attempts made by LLM_speaker&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;this can inform the reward function so that the LLM_speaker can learn the number of attempts&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=6;spacingRight=6;fontColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="660" y="360" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-54" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;dashed=1;" edge="1" parent="1" source="xELkamH10cSAUg8blqq6-53" target="xELkamH10cSAUg8blqq6-45">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="880" y="-20" />
              <mxPoint x="880" y="-20" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-53" value="LLM_embedding" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="-120" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-55" value="an embedding model can compute a continuous error/distance value (e.g. cosine similarity) between the TARGET and GUESS WORD to offer a more precise feedback score." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=6;spacingRight=6;fontColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="950" y="-120" width="200" height="110" as="geometry" />
        </mxCell>
        <mxCell id="xELkamH10cSAUg8blqq6-56" value="does the LLM_guesser also need to be trained or can its weights remain frozen?" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=6;spacingRight=6;fontColor=#D6B656;" vertex="1" parent="1">
